<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="BaldGrabber.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:BaldGrabber"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:BaldGrabber.ViewModels"
    xmlns:models="using:BaldGrabber.Models"
    xmlns:conv="using:BaldGrabber.Converters"
    mc:Ignorable="d"
    Background="#121826">

    <Page.Resources>
        <conv:NullToBoolConverter x:Key="NullToBoolConverter"/>
        <conv:SelectedStateConverter x:Key="SelectedStateConverter"/>
        <conv:EmptyToCollapsedConverter x:Key="EmptyToCollapsedConverter"/>
        <conv:InvertBoolToVisibilityConverter x:Key="InvertBoolToVisibilityConverter"/>
        <conv:IdToForegroundConverter x:Key="IdToForegroundConverter" NormalBrush="{StaticResource WhiteBrush}" PlaceholderBrush="{StaticResource SecondaryBrush}"/>
        <SolidColorBrush x:Key="BackgroundBrush" Color="#121826"/>
        <SolidColorBrush x:Key="CardBrush" Color="#1F2434"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#8B5CF6"/>
        <SolidColorBrush x:Key="AudioAccentBrush" Color="#8B5CF6"/>
        <SolidColorBrush x:Key="VideoAccentBrush" Color="#06B6D4"/>
        <SolidColorBrush x:Key="WhiteBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="SecondaryBrush" Color="#C3C6D4"/>
        <SolidColorBrush x:Key="ErrorBrush" Color="#EF4444"/>
        <SolidColorBrush x:Key="SuccessBrush" Color="#22C55E"/>
        <SolidColorBrush x:Key="TabInactiveBrush" Color="#2A2F42"/>
        <SolidColorBrush x:Key="TabActiveAudioBrush" Color="#8B5CF6"/>
        <SolidColorBrush x:Key="TabActiveVideoBrush" Color="#06B6D4"/>

        <Style x:Key="DarkComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="#181D2C"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#3B4256"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal"/>
                                    <VisualState x:Name="PointerOver">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="Background" Storyboard.TargetProperty="Background">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="#2A2F42"/>
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="Background" Storyboard.TargetProperty="Background">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="#2A2F42"/>
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Disabled">
                                        <Storyboard>
                                            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="ContentPresenter" Storyboard.TargetProperty="Opacity">
                                                <DiscreteDoubleKeyFrame KeyTime="0" Value="0.5"/>
                                            </DoubleAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                            <Border x:Name="Background" 
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="{TemplateBinding CornerRadius}"
                                    Padding="{TemplateBinding Padding}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="32"/>
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter x:Name="ContentPresenter"
                                                      Grid.Column="0"
                                                      Content="{TemplateBinding SelectedItem}"
                                                      ContentTemplate="{TemplateBinding ItemTemplate}"
                                                      HorizontalAlignment="Stretch"
                                                      VerticalAlignment="Center"/>
                                    <FontIcon x:Name="DropDownGlyph"
                                              Grid.Column="1"
                                              FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                              Glyph="&#xE0E5;"
                                              FontSize="12"
                                              Foreground="{TemplateBinding Foreground}"
                                              HorizontalAlignment="Right"
                                              VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                            <Popup x:Name="Popup">
                                <Border x:Name="PopupBorder"
                                        Background="{StaticResource ComboBoxDropDownBackground}"
                                        BorderBrush="{StaticResource ComboBoxDropDownBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="10">
                                    <ScrollViewer x:Name="ScrollViewer"
                                                  MinWidth="150"
                                                  MaxHeight="300">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <SolidColorBrush x:Key="ComboBoxDropDownBackground" Color="#0F1318"/>
        <SolidColorBrush x:Key="ComboBoxDropDownBorderBrush" Color="#3B4256"/>
        <SolidColorBrush x:Key="ComboBoxItemBackgroundPointerOver" Color="#1E2530"/>
        <SolidColorBrush x:Key="ComboBoxItemBackgroundSelected" Color="#1E2530"/>
        <SolidColorBrush x:Key="ComboBoxItemBackgroundSelectedPointerOver" Color="#283040"/>
        <SolidColorBrush x:Key="ComboBoxItemForeground" Color="White"/>
        <SolidColorBrush x:Key="ComboBoxItemForegroundPointerOver" Color="White"/>
        <SolidColorBrush x:Key="ComboBoxItemForegroundSelected" Color="White"/>
        <SolidColorBrush x:Key="ComboBoxItemForegroundSelectedPointerOver" Color="White"/>
        <Storyboard x:Name="StatusPulseStoryboard">
            <DoubleAnimation
                Storyboard.TargetName="StatusText"
                Storyboard.TargetProperty="Opacity"
                From="1" To="0.3"
                Duration="0:0:1"
                AutoReverse="True"
                RepeatBehavior="Forever"/>
        </Storyboard>
        <Storyboard x:Name="CheckingFormatsStoryboard">
            <DoubleAnimation
                Storyboard.TargetName="VideoQualityComboBox"
                Storyboard.TargetProperty="Opacity"
                From="1" To="0.3"
                Duration="0:0:1"
                AutoReverse="True"
                RepeatBehavior="Forever"/>
        </Storyboard>
    </Page.Resources>

    <Grid x:Name="MainPageRoot" Padding="28,20" Background="#121826">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Hero Section -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Image
                Grid.Column="0"
                Source="Assets/bad.png"
                Width="64" Height="64"
                Margin="0,0,16,0"/>

            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <TextBlock
                    x:Name="TitleText"
                    FontSize="28"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource WhiteBrush}"/>
                <TextBlock
                    x:Name="SubtitleText"
                    FontSize="14"
                    Foreground="{StaticResource SecondaryBrush}"
                    Margin="0,2,0,0"/>
            </StackPanel>
        </Grid>

        <!-- Tabs -->
        <Grid Grid.Row="1" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border x:Name="AudioTabBorder" Grid.Column="0" CornerRadius="12" Padding="0">
                <Button
                    x:Name="AudioTabButton"
                    Click="AudioTab_Click"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="0,12"
                    HorizontalAlignment="Stretch">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="8">
                        <FontIcon
                            FontFamily="{ThemeResource SymbolThemeFontFamily}"
                            Glyph="&#xE8D6;"
                            FontSize="18"/>
                        <TextBlock
                            x:Name="AudioTabText"
                            FontSize="15"
                            FontWeight="SemiBold"
                            VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Border>

            <Border x:Name="VideoTabBorder" Grid.Column="2" CornerRadius="12" Padding="0">
                <Button
                    x:Name="VideoTabButton"
                    Click="VideoTab_Click"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="0,12"
                    HorizontalAlignment="Stretch">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="8">
                        <FontIcon
                            FontFamily="{ThemeResource SymbolThemeFontFamily}"
                            Glyph="&#xE714;"
                            FontSize="18"/>
                        <TextBlock
                            x:Name="VideoTabText"
                            FontSize="15"
                            FontWeight="SemiBold"
                            VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Border>
        </Grid>

        <!-- Main Card -->
        <Border
            Grid.Row="2"
            Background="{StaticResource CardBrush}"
            CornerRadius="20"
            Padding="22"
            BorderBrush="#3B4256"
            BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- URL Section -->
                <StackPanel Grid.Row="0" Margin="0,0,0,12">
                    <TextBlock
                        x:Name="UrlLabel"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource WhiteBrush}"
                        Margin="0,0,0,6"/>
                    <Border
                        x:Name="UrlInputBorder"
                        BorderThickness="2"
                        CornerRadius="10"
                        Padding="0,4">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <FontIcon
                                Grid.Column="0"
                                FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                Glyph="&#xE71B;"
                                FontSize="18"
                                Margin="14,6,10,6"
                                VerticalAlignment="Center"/>
                            <TextBox
                                Grid.Column="1"
                                x:Name="UrlTextBox"
                                TextChanged="UrlTextBox_TextChanged"
                                PlaceholderText="Paste YouTube video link"
                                Background="Transparent"
                                Foreground="{StaticResource WhiteBrush}"
                                PlaceholderForeground="#6B7280"
                                Padding="0,10"
                                FontSize="15">
                                <TextBox.Template>
                                    <ControlTemplate TargetType="TextBox">
                                        <Border Background="Transparent">
                                            <ScrollViewer
                                                x:Name="ContentElement"
                                                VerticalAlignment="Center"
                                                HorizontalScrollBarVisibility="Disabled"
                                                VerticalScrollBarVisibility="Disabled"/>
                                        </Border>
                                    </ControlTemplate>
                                </TextBox.Template>
                            </TextBox>
                            <Button
                                Grid.Column="2"
                                Click="ClearUrlButton_Click"
                                BorderThickness="0"
                                Background="Transparent"
                                Margin="0,0,10,0"
                                Padding="6">
                                <FontIcon
                                    FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                    Glyph="&#xE711;"
                                    FontSize="14"
                                    Foreground="{StaticResource SecondaryBrush}"/>
                            </Button>
                        </Grid>
                    </Border>
                </StackPanel>

                <!-- Folder Section -->
                <StackPanel Grid.Row="1" Margin="0,0,0,12">
                    <TextBlock
                        x:Name="FolderLabel"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource WhiteBrush}"
                        Margin="0,0,0,6"/>
                    <Border
                        BorderBrush="#3B4256"
                        BorderThickness="1"
                        CornerRadius="10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border
                                Grid.Column="0"
                                Background="#181D2C"
                                CornerRadius="10,0,0,10"
                                Padding="14,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <FontIcon
                                        Grid.Column="0"
                                        FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                        Glyph="&#xE838;"
                                        FontSize="18"
                                        Foreground="{StaticResource SecondaryBrush}"
                                        Margin="0,0,10,0"
                                        VerticalAlignment="Center"/>
                                    <TextBox
                                        Grid.Column="1"
                                        x:Name="FolderTextBox"
                                        Text="{Binding OutputFolder, Mode=TwoWay}"
                                        TextChanged="FolderTextBox_TextChanged"
                                        Background="Transparent"
                                        Foreground="{StaticResource WhiteBrush}"
                                        FontSize="15"
                                        MinHeight="0"
                                        VerticalAlignment="Center"
                                        Padding="0,10">
                                        <TextBox.Template>
                                            <ControlTemplate TargetType="TextBox">
                                                <Border Background="Transparent">
                                                    <ScrollViewer
                                                        x:Name="ContentElement"
                                                        VerticalAlignment="Center"
                                                        HorizontalScrollBarVisibility="Disabled"
                                                        VerticalScrollBarVisibility="Disabled"/>
                                                </Border>
                                            </ControlTemplate>
                                        </TextBox.Template>
                                    </TextBox>
                                </Grid>
                            </Border>
                            <Button
                                Grid.Column="1"
                                x:Name="BrowseButton"
                                Command="{Binding BrowseFolderCommand}"
                                Background="#2A2F42"
                                Foreground="{StaticResource WhiteBrush}"
                                BorderThickness="0"
                                CornerRadius="0,10,10,0"
                                Padding="20,10"
                                FontSize="15"/>
                        </Grid>
                    </Border>
                </StackPanel>

                <!-- Quality Section -->
                <StackPanel Grid.Row="2" Margin="0,0,0,12">
                    <TextBlock
                        x:Name="QualityLabel"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource WhiteBrush}"
                        Margin="0,0,0,6"/>
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="44"/>
                        </Grid.ColumnDefinitions>
                        <ComboBox
                            x:Name="AudioQualityComboBox"
                            Grid.Column="0"
                            Style="{StaticResource DarkComboBox}"
                            ItemsSource="{Binding AudioQualities}"
                            DisplayMemberPath="Name"
                            SelectedItem="{Binding SelectedAudioQuality, Mode=TwoWay}"
                            HorizontalAlignment="Stretch"/>
                        <ComboBox
                            x:Name="VideoQualityComboBox"
                            Grid.Column="0"
                            Style="{StaticResource DarkComboBox}"
                            ItemsSource="{Binding VideoQualities}"
                            SelectedItem="{Binding SelectedVideoQuality, Mode=TwoWay}"
                            IsEnabled="{Binding CanSelectVideoQuality}"
                            HorizontalAlignment="Stretch"
                            Loaded="VideoQualityComboBox_Loaded">
                            <ComboBox.Resources>
                                <DataTemplate x:Key="VideoQualityItemTemplate" x:DataType="models:VideoQualityOption">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="{Binding Name}" FontSize="15" FontWeight="Medium">
                                            <TextBlock.Foreground>
                                                <Binding Path="Id" Converter="{StaticResource IdToForegroundConverter}"/>
                                            </TextBlock.Foreground>
                                        </TextBlock>
                                        <TextBlock Text="недоступно" Foreground="#EF4444" FontSize="11" VerticalAlignment="Center" Visibility="{Binding IsAvailable, Converter={StaticResource InvertBoolToVisibilityConverter}}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ComboBox.Resources>
                            <ComboBox.ItemTemplate>
                                <StaticResource ResourceKey="VideoQualityItemTemplate"/>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <Button
                            x:Name="FragmentButton"
                            Grid.Column="1"
                            Click="FragmentButton_Click"
                            Background="#2A2F42"
                            BorderThickness="0"
                            CornerRadius="10"
                            Padding="0"
                            ToolTipService.ToolTip="Фрагмент"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch">
                            <FontIcon
                                x:Name="FragmentButtonIcon"
                                FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                Glyph="&#xE916;"
                                FontSize="18"
                                Foreground="{StaticResource SecondaryBrush}"/>
                        </Button>
                    </Grid>
                </StackPanel>



                <!-- Download Button -->
                <Button
                    Grid.Row="4"
                    x:Name="DownloadButton"
                    Command="{Binding DownloadCommand}"
                    Foreground="White"
                    BorderThickness="0"
                    CornerRadius="12"
                    Padding="0,12"
                    FontSize="16"
                    FontWeight="SemiBold"
                    HorizontalAlignment="Stretch"
                    Margin="0,0,0,12"/>

                <!-- Status Section -->
                <StackPanel Grid.Row="5" Margin="0,0,0,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            x:Name="StatusText"
                            Grid.Column="0"
                            Text="{Binding Status}"
                            FontSize="14"
                            Foreground="{StaticResource WhiteBrush}"/>
                        <TextBlock
                            Grid.Column="1"
                            Text="{Binding ProgressText}"
                            FontSize="14"
                            Foreground="{StaticResource WhiteBrush}"/>
                    </Grid>
                    <ProgressBar
                        x:Name="ProgressBar"
                        Value="{Binding Progress}"
                        Maximum="1"
                        IsIndeterminate="{Binding IsIndeterminate}"
                        Height="6"
                        CornerRadius="3"
                        Margin="0,6,0,0"
                        Background="#2A2F42"/>
                    <TextBlock
                        Text="{Binding FormatsStatus}"
                        FontSize="12"
                        Foreground="{StaticResource SecondaryBrush}"
                        Margin="0,0,0,0"/>
                </StackPanel>

                <!-- Footer -->
                <Border
                    Grid.Row="6"
                    BorderThickness="0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel
                            Grid.Column="0"
                            Orientation="Horizontal"
                            Spacing="6"
                            VerticalAlignment="Center">
                            <FontIcon
                                FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                Glyph="&#xEC32;"
                                FontSize="16"
                                Foreground="#6B7280"
                                VerticalAlignment="Center"/>
                            <HyperlinkButton
                                x:Name="SupportAuthor"
                                NavigateUri="https://send.monobank.ua/jar/3bTz2pbnrD"
                                Foreground="#8B5CF6"
                                VerticalAlignment="Center"
                                Padding="0"
                                MinHeight="0">
                                <HyperlinkButton.Template>
                                    <ControlTemplate TargetType="HyperlinkButton">
                                        <ContentPresenter
                                            Content="{TemplateBinding Content}"
                                            Foreground="{TemplateBinding Foreground}"
                                            Padding="{TemplateBinding Padding}"
                                            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                            VerticalAlignment="Center"/>
                                    </ControlTemplate>
                                </HyperlinkButton.Template>
                                <TextBlock
                                    FontSize="13"
                                    Foreground="#8B5CF6"/>
                            </HyperlinkButton>
                        </StackPanel>
                        <Button
                            Grid.Column="1"
                            x:Name="OpenFolderButton"
                            Command="{Binding OpenFolderCommand}"
                            IsEnabled="{Binding DownloadedFilePath, Converter={StaticResource NullToBoolConverter}}"
                            Background="#2A2F42"
                            Foreground="{StaticResource WhiteBrush}"
                            BorderThickness="0"
                            CornerRadius="10"
                            Padding="16,10"
                            FontSize="14"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Page>
